# Build outputs
out/
*.AppImage
*.AppImage.zsync
AppDir/
*.AppDir/
squashfs-root/

# Auto-generated example icons (created at build time by ImageMagick).
examples/*/hello-*.png

# Downloaded tools (fetched into the build container, not committed)
tools/
appimagetool*
linuxdeploy*

# Language-specific build artifacts
# Go
examples/*/build/
.gocache/
*.exe
*.test

# Python
__pycache__/
*.pyc
.venv/

# C/C++
*.o
*.so

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
